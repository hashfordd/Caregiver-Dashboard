{
  "name": "alzheimers-care-saas",
  "version": "0.0.0",
  "private": true,
  "description": "ENG40011 caregiver dashboard SaaS — monorepo root",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "broker:up": "docker compose -f mqtt/docker-compose.yml up -d",
    "broker:down": "docker compose -f mqtt/docker-compose.yml down",
    "broker:logs": "docker compose -f mqtt/docker-compose.yml logs -f mosquitto",
    "broker:certs": "bash mqtt/scripts/gen-certs.sh",
    "broker:creds": "bash mqtt/scripts/gen-creds.sh",
    "bridge:start": "deno run --env-file=apps/edge/.env --allow-net --allow-env --allow-read --import-map=apps/edge/deno.json apps/edge/functions/mqtt_bridge/longRunning.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "seed": "npm run start --workspace @alzcare/seed",
    "prepare": "husky"
  },
  "overrides": {
    "vite": "5.4.10",
    "postcss": "8.4.47"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@types/node": "20.17.0",
    "eslint": "9.13.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "globals": "15.11.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.13.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
