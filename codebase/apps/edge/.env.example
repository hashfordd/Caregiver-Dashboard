# Edge function environment.
# `supabase functions deploy` reads from `supabase/.env` for cloud deploys; this
# file documents what each function expects.

# Supabase project (service-role key — keep server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MQTT broker (consumed by mqtt_bridge longRunning mode).
# Plain mqtt:// for local dev (port 1883); switch to mqtts:// + 8883 in any
# non-team deployment. The dev password is set by `npm run broker:creds`.
MQTT_BROKER_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=backend-bridge
MQTT_PASSWORD=<set MQTT_BRIDGE_PASSWORD via gen-creds.sh>

# Logging
LOG_LEVEL=info
