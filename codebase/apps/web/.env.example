# Vite picks these up at build time. Copy to apps/web/.env.local and fill.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# F9 outdoor map. Provision a token at https://account.mapbox.com/access-tokens/.
# Without a token, the outdoor view renders a "Map unavailable" placeholder
# rather than crashing — the rest of the dashboard works as normal.
VITE_MAPBOX_TOKEN=
