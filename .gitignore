# Project-root gitignore. The npm monorepo at codebase/ has its own
# .gitignore covering node_modules, dist, .env, etc. This file covers
# project-root level concerns + IDE / OS noise.

# OS / editor noise
.DS_Store
Thumbs.db
*.swp

# Stray node_modules from before the codebase/ restructure (the npm
# workspace now installs into codebase/node_modules — the parent-level
# folder, if it exists, is leftover).
/node_modules/

# Project-level build artefacts (none today; placeholder).
*.log

# Local-only Claude config — already at .claude/ (not staged).
.claude/
